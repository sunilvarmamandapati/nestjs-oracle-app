# Application
NODE_ENV=development
PORT=3000

# Oracle Database
# When running locally against Docker Oracle: DB_HOST=localhost, DB_SERVICE_NAME=FREEPDB1
# When running inside Docker Compose:         DB_HOST=oracle,     DB_SERVICE_NAME=FREEPDB1
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE_NAME=FREEPDB1
DB_USERNAME=appuser
DB_PASSWORD=AppUser_123
DB_POOL_MIN=2
DB_POOL_MAX=10
